# LLM integration configuration
# Required: API key for OpenRouter/OpenAI-compatible endpoint
LLM_API_KEY=your_api_key_here

# Optional: Base URL for compatible chat completions API
LLM_BASE_URL=https://openrouter.ai/api/v1

# Optional: Model identifier
LLM_MODEL=openai/gpt-4o-mini

# Optional: Request timeout in seconds
LLM_TIMEOUT=30

# Optional: Retry attempts for transient failures (0 disables retries)
LLM_MAX_RETRIES=3

# Optional: OpenRouter attribution headers
LLM_HTTP_REFERER=https://your-app.example
LLM_APP_TITLE=QA Orchestrator

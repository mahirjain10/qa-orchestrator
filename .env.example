# LLM Integration Configuration
# The system supports three providers: OpenAI, OpenRouter, and Google Gemini.
# Provider is auto-detected from model name, or can be explicitly set.

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
# LLM_PROVIDER=auto|openai|openrouter|gemini
# - "auto" (default): Detects provider from model name prefix
#   - "gpt-*", "o1*", "o3*" -> OpenAI
#   - "gemini*", "google/*" -> Gemini
#   - Everything else -> OpenRouter
# - Explicit: Forces a specific provider regardless of model name
LLM_PROVIDER=auto

# =============================================================================
# OPENAI CONFIGURATION
# =============================================================================
# Direct OpenAI API access
# Endpoint: https://api.openai.com/v1/chat/completions
# Models: gpt-4o, gpt-4o-mini, o1, o3, etc.
#
# LLM_API_KEY=sk-proj-your_openai_api_key
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai

# =============================================================================
# OPENROUTER CONFIGURATION (Default)
# =============================================================================
# OpenRouter acts as a unified gateway to multiple providers.
# Endpoint: https://openrouter.ai/api/v1/chat/completions
# Models: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, google/gemini-pro, etc.
#
# LLM_API_KEY=sk-or-v1-your_openrouter_key
# LLM_MODEL=openai/gpt-4o-mini
# LLM_PROVIDER=openrouter

# Optional: OpenRouter attribution headers (for rankings on openrouter.ai)
LLM_HTTP_REFERER=https://your-app.example
LLM_APP_TITLE=QA Orchestrator

# Optional: OpenRouter provider routing preferences
# LLM_PROVIDER_PRIORITY=OpenAI,Anthropic
# LLM_PROVIDER_ONLY=openai
# LLM_ALLOW_FALLBACKS=false

# =============================================================================
# GEMINI CONFIGURATION
# =============================================================================
# Direct Google Gemini API access
# Endpoint: https://generativelanguage.googleapis.com/v1beta/models/{MODEL}:generateContent
# Models: gemini-2.0-flash, gemini-2.5-pro, etc.
#
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
# LLM_PROVIDER=gemini
#
# Note: If GEMINI_API_KEY is not set, LLM_API_KEY will be used as fallback.
# Note: If GEMINI_MODEL is not set, defaults to gemini-2.0-flash.

# =============================================================================
# REASONING / THINKING (OpenRouter / DeepSeek / Gemini)
# =============================================================================

# Optional: Reasoning effort for GPT-5, o1/o3/o4, and DeepSeek V4 models.
# Valid values: none, minimal, low, medium, high, xhigh
# LLM_REASONING_EFFORT=high

# Optional: Thinking mode for DeepSeek / Gemini thinking models.
# Valid types: enabled, disabled, max
# LLM_THINKING_TYPE=enabled

# Optional: Token budget for thinking (model default is used when omitted).
# LLM_THINKING_BUDGET=4000

# =============================================================================
# SHARED CONFIGURATION
# =============================================================================

# Required: API key for the selected provider
# - OpenAI/OpenRouter: LLM_API_KEY
# - Gemini: GEMINI_API_KEY (or LLM_API_KEY as fallback)
LLM_API_KEY=your_api_key_here

# Optional: Model identifier (auto-detected provider uses this to route)
LLM_MODEL=openai/gpt-4o-mini

# Optional: Gemini-specific model (used when provider=gemini)
GEMINI_MODEL=gemini-2.0-flash

# Optional: Gemini-specific API key (falls back to LLM_API_KEY)
GEMINI_API_KEY=

# Optional: Request timeout in seconds
LLM_TIMEOUT=30

# Optional: Retry attempts for transient failures (0 disables retries)
LLM_MAX_RETRIES=3

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# Example 1: OpenAI Direct
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-proj-xxx
# LLM_MODEL=gpt-4o-mini

# Example 2: OpenRouter (Default)
# LLM_PROVIDER=auto
# LLM_API_KEY=sk-or-v1-xxx
# LLM_MODEL=openai/gpt-4o-mini

# Example 3: Gemini Direct
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza-xxx
# LLM_MODEL=gemini-2.0-flash

# Example 4: OpenRouter with DeepSeek V4 Pro + reasoning
# LLM_PROVIDER=auto
# LLM_API_KEY=sk-or-v1-xxx
# LLM_MODEL=deepseek/deepseek-v4-pro
# LLM_REASONING_EFFORT=high

# Example 5: OpenRouter with DeepSeek V4 Pro + thinking mode (budget optional)
# LLM_PROVIDER=auto
# LLM_API_KEY=sk-or-v1-xxx
# LLM_MODEL=deepseek/deepseek-v4-pro
# LLM_THINKING_TYPE=enabled
# LLM_THINKING_BUDGET=4000

# Example 6: Gemini with thinking (budget optional)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza-xxx
# LLM_MODEL=gemini-2.5-pro
# LLM_THINKING_TYPE=enabled
